PREFIX sio: <http://semanticscience.org/resource/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?firstName ?lastName ?missionName WHERE {
	?astronaut a foaf:Person .
  	?astronaut foaf:firstName ?firstName .
	?astronaut foaf:lastName ?lastName .
  
  	?astronaut sio:SIO_000228 ?role .
  	?role sio:SIO_000356 ?mission .
  	?mission foaf:name ?missionName .
}